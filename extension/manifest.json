{
  "manifest_version": 3,
  "name": "Fontify Inspector",
  "version": "1.0.0",
  "description": "Hover over any element to inspect its font-family, size, weight, and color.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Fontify Inspector"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
